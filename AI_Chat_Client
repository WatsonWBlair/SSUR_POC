import gradio as gr
import subprocess
import threading
import time
import websocket

AI_AUDIO_OUTPUT_PATH = "ai_output.mp3"
WS_URL = "ws://localhost:8000/ws"


# Send audio to server and receive AI response
def send_and_receive_via_ws(audio_path):
    try:
        with open(audio_path, 'rb') as f:
            data = f.read()

        ws = websocket.create_connection(WS_URL)
        start = time.time()

        ws.send_binary(data)
        response = ws.recv()
        end = time.time()

        with open(AI_AUDIO_OUTPUT_PATH, "wb") as out:
            out.write(response)

        latency = round(end - start, 3)
        print(f"✅ Roundtrip time: {latency}s")
        return AI_AUDIO_OUTPUT_PATH, latency
    except Exception as e:
        print(f"❌ Error: {e}")
        return None, None


# Playback function
def play_audio_file(file_path):
    subprocess.run(['ffplay', '-nodisp', '-autoexit', file_path],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


# Gradio handler
def handle_voice_input(audio_path):
    if audio_path is None:
        return None, "No audio input", None

    ai_path, latency = send_and_receive_via_ws(audio_path)
    if ai_path:
        threading.Thread(target=play_audio_file, args=(ai_path,)).start()
        return ai_path, f"{latency} seconds", None
    else:
        return None, "Failed to get response", None


# Gradio UI
with gr.Blocks() as demo:
    gr.Markdown("🎙️ **Voice AI WebSocket Client**")

    with gr.Row():
        mic = gr.Audio(label="🎤 Record Your Voice")  # No "type" or "format"
        response_audio = gr.Audio(label="🗣️ AI Response", interactive=False)

    latency_text = gr.Textbox(label="⏱️ Roundtrip Time (sec)", interactive=False)
    submit_btn = gr.Button("Send to AI")

    submit_btn.click(
        fn=handle_voice_input,
        inputs=[mic],
        outputs=[response_audio, latency_text, gr.State()]
    )

demo.launch(server_name="0.0.0.0", server_port=7000)
